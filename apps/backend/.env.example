# Production Environment Variables
NODE_ENV=production
PORT=3001

# PostgreSQL (Managed Database)
# DigitalOcean will provide DATABASE_URL in production
DATABASE_URL=postgres://user:pass@host:port/dbname

# Legacy DB fields (fallback)
DB_HOST=localhost
DB_PORT=5434
DB_USERNAME=blitzr_admin
DB_PASSWORD=blitzr_dev_secret
DB_DATABASE=blitzr_prime

# Redis (Managed Redis)
# DigitalOcean will provide REDIS_URL in production
REDIS_URL=rediss://user:pass@host:port
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT Secrets
JWT_SECRET=your_super_secret_key_change_me
JWT_EXPIRATION=7d

# Sarvam AI (Optional)
SARVAM_API_KEY=your_key_here

# Google Auth (Required for Verified Identity)
GOOGLE_CLIENT_ID=your_google_client_id_here
