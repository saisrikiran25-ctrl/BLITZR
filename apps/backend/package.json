{
    "name": "@blitzr/backend",
    "version": "1.0.0",
    "private": true,
    "description": "BLITZR-PRIME NestJS Backend",
    "scripts": {
        "build": "nest build",
        "dev": "ts-node -r tsconfig-paths/register src/main.ts",
        "start": "node deploy-migrate.js && node dist/apps/backend/src/main.js",
        "start:prod": "node dist/apps/backend/src/main.js",
        "migrate": "ts-node -r tsconfig-paths/register run-migration.ts",
        "migrate:prod": "node deploy-migrate.js",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:e2e": "jest --config ./test/jest-e2e.json"
    },
    "dependencies": {
        "@nestjs/bullmq": "^11.0.4",
        "@nestjs/cache-manager": "^3.1.0",
        "@nestjs/common": "^10.3.0",
        "@nestjs/config": "^3.1.0",
        "@nestjs/core": "^10.3.0",
        "@nestjs/jwt": "^10.2.0",
        "@nestjs/passport": "^10.0.3",
        "@nestjs/platform-express": "^10.3.0",
        "@nestjs/platform-socket.io": "^10.3.0",
        "@nestjs/schedule": "^4.1.2",
        "@nestjs/swagger": "^11.2.6",
        "@nestjs/typeorm": "^10.0.1",
        "@nestjs/websockets": "^10.3.0",
        "bcrypt": "^5.1.1",
        "bullmq": "^5.71.0",
        "cache-manager": "^7.2.8",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.4",
        "google-auth-library": "^10.6.2",
        "ioredis": "^5.3.2",
        "openai": "^6.32.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "pg": "^8.20.0",
        "reflect-metadata": "^0.2.1",
        "rxjs": "^7.8.1",
        "socket.io": "^4.7.0",
        "typeorm": "^0.3.19"
    },
    "devDependencies": {
        "@nestjs/cli": "^10.3.0",
        "@nestjs/schematics": "^10.1.0",
        "@nestjs/testing": "^10.3.0",
        "@types/bcrypt": "^5.0.2",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.11",
        "@types/node": "^20.11.0",
        "@types/passport-jwt": "^4.0.0",
        "jest": "^29.7.0",
        "nodemon": "^3.1.14",
        "ts-jest": "^29.1.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.3.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": ".",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "moduleNameMapper": {
            "^@blitzr/shared$": "<rootDir>/../../packages/shared/src/index",
            "^@blitzr/shared/(.*)$": "<rootDir>/../../packages/shared/src/$1"
        },
        "collectCoverageFrom": [
            "src/**/*.(t|j)s"
        ],
        "coverageDirectory": "./coverage",
        "testEnvironment": "node"
    }
}
