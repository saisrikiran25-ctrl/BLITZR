{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": ".",
        "baseUrl": "./",
        "paths": {
            "@blitzr/shared": [
                "../../packages/shared/src"
            ],
            "@blitzr/shared/*": [
                "../../packages/shared/src/*"
            ],
            "@/*": [
                "src/*"
            ]
        },
        "strictPropertyInitialization": false,
        "noUnusedLocals": false,
        "noUnusedParameters": false
    },
    "include": [
        "src/**/*",
        "../../packages/shared/src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "test"
    ]
}