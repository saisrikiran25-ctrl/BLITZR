{
  "name": "blitzr-prime",
  "version": "1.0.0",
  "private": true,
  "description": "BLITZR-PRIME: Campus Social-Equity Exchange",
  "workspaces": [
    "apps/backend",
    "apps/mobile",
    "packages/shared"
  ],
  "scripts": {
    "backend:dev": "npm run dev --workspace=apps/backend",
    "backend:build": "npm run build --workspace=apps/backend",
    "backend:test": "npm run test --workspace=apps/backend",
    "shared:build": "npm run build --workspace=packages/shared",
    "start": "node blitzr-migrate.js && node apps/backend/dist/apps/backend/src/main.js"
  },
  "dependencies": {
    "pg": "^8.20.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@babel/preset-flow": "^7.27.1",
    "@types/bcrypt": "^6.0.0",
    "@types/pg": "^8.18.0",
    "@types/uuid": "^10.0.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-plugin-transform-import-meta": "^2.3.3",
    "react-native-worklets": "0.7.0",
    "react-native-worklets-core": "^1.6.3"
  }
}
