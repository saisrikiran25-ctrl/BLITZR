# ============================================================
# BLITZR-PRIME Backend Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=blitzr_admin
DB_PASSWORD=blitzr_dev_secret
DB_DATABASE=blitzr_prime

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
TRADE_QUEUE_IDLE_SHUTDOWN_SECONDS=300
TRADE_QUEUE_POP_TIMEOUT_SECONDS=2
TRADE_QUEUE_MAX_RETRY_ATTEMPTS=3

# JWT
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRATION=7d
ADMIN_JWT_SECRET=your-admin-secret-key-change-this-in-production

# OpenAI
OPENAI_API_KEY=your-openai-key

# Bonding Curve
SCALING_CONSTANT_K=200

# Rate Limiting
MAX_TRADES_PER_MINUTE=5
