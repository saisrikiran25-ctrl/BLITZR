# ============================================================
# BLITZR-PRIME Backend Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# Server
PORT=3000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=blitzr_admin
DB_PASSWORD=blitzr_dev_secret
DB_DATABASE=blitzr_prime

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_SECRET=your-super-secret-key-change-this-in-production
JWT_EXPIRATION=7d

# Bonding Curve
SCALING_CONSTANT_K=200

# Rate Limiting
MAX_TRADES_PER_MINUTE=5
