{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "lib": [
      "es2019",
      "es2020.bigint",
      "es2020.date",
      "es2020.number",
      "es2020.promise",
      "es2020.string",
      "es2020.symbol.wellknown",
      "es2021.promise",
      "es2021.string",
      "es2021.weakref",
      "es2022.array",
      "es2022.object",
      "es2022.string",
      "dom"
    ],
    "types": [
      "jest"
    ],
    "baseUrl": "./",
    "paths": {
      "@blitzr/shared": [
        "../../packages/shared/src"
      ],
      "@blitzr/shared/*": [
        "../../packages/shared/src/*"
      ]
    },
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "esModuleInterop": true
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    "../../packages/shared/src/**/*.ts"
  ],
  "exclude": [
    "**/node_modules",
    "**/Pods",
    "android",
    "ios"
  ]
}